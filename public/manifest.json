{
  "manifest_version": 3,
  "name": "Social Page Translator",
  "version": "0.1.0",
  "description": "Translate YouTube, Instagram, and X page text with OpenAI or MiMo.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.instagram.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://api.openai.com/*",
    "https://api.mimo-v2.com/*",
    "https://api.xiaomimimo.com/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*",
        "https://www.instagram.com/*",
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["assets/content.js"],
      "css": ["assets/content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/index.html",
  "action": {
    "default_title": "Social Translator",
    "default_popup": "src/popup/index.html"
  }
}
